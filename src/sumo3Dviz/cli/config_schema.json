{
  "type": "object",
  "properties": {
    "rendering_parameters": {
      "type": "object",
      "properties": {
        "record_video": {
          "type": "boolean",
          "default": true
        },
        "headless": {
          "type": "boolean",
          "default": false
        },
        "video_width_px": {
          "type": "integer",
          "default": 1140
        },
        "video_height_px": {
          "type": "integer",
          "default": 900
        },
        "video_fps": {
          "type": "number",
          "default": 25.0
        }
      },
      "additionalProperties": false
    },
    "visualization_parameters": {
      "type": "object",
      "properties": {
        "show_other_vehicles": {
          "type": "boolean",
          "default": true
        },
        "show_signals": {
          "type": "boolean",
          "default": true
        },
        "lane_width": {
          "type": "number",
          "default": 3.2
        },
        "sep_line_width": {
          "type": "number",
          "default": 0.2
        },
        "tree_scale_1": {
          "type": "number",
          "default": 0.2
        },
        "tree_scale_2": {
          "type": "number",
          "default": 0.5
        },
        "tree_size_variability": {
          "type": "number",
          "default": 1.0
        },
        "tree_color_variability": {
          "type": "number",
          "default": 0.1
        },
        "sky_texture": {
          "type": "string",
          "enum": ["sky_blue", "sky_cloudy", "sky_overcast", "sky_dawn", "sky_night_stars", "sky_night_clear", "sky_night_forest", "sky_night_desert", "sky_halloween"],
          "default": "sky_cloudy"
        },
        "ground_texture": {
          "type": "string",
          "enum": ["ground_grass", "ground_stone", "ground_sand", "ground_chess", "ground_chesslarge", "ground_halloween"],
          "default": "ground_grass"
        },
        "viewer_height": {
          "type": "number",
          "default": 1.5
        }
      },
      "additionalProperties": false
    },
    "path_parameters": {
      "type": "object",
      "properties": {
        "trajectory_file": {
          "type": "string"
        },
        "sumo_network_file": {
          "type": "string"
        },
        "traffic_signal_states_file": {
          "type": "string"
        },
        "fence_lines_file": {
          "type": "string"
        },
        "shops_positions_file": {
          "type": "string"
        },
        "homes_positions_file": {
          "type": "string"
        },
        "blocks_positions_file": {
          "type": "string"
        },
        "tree_positions_file": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "signal_parameters": {
      "type": "object",
      "properties": {
        "signal_design": {
          "type": "string",
          "enum": ["simple", "three_headed", "countdown_timer"],
          "default": "three_headed"
        },
        "traffic_light_id": {
          "type": "string"
        },
        "traffic_light_positions": {
          "type": "object",
          "properties": {
            "ramps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "pos_x": { "type": "number" },
                  "pos_y": { "type": "number" },
                  "stop_line_a": { "type": "number" },
                  "stop_line_b": { "type": "number" },
                  "stop_line_c": { "type": "number" },
                  "stop_line_d": { "type": "number" }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "mode_parameters": {
      "type": "object",
        "properties": {
          "eulerian": {
            "type": "object",
            "properties": {
              "simtime_start": {
                "type": "number"
              },
              "simtime_end": {
                "type": "number"
              },
              "ego_identifier": {
                "type": "string"
              },
              "camera_position": {
                "type": "object",
                "properties": {
                  "pos_x": { "type": "number" },
                  "pos_y": { "type": "number" },
                  "pos_z": { "type": "number" },
                  "ori_h": { "type": "number" },
                  "ori_p": { "type": "number" },
                  "ori_r": { "type": "number" }
                }
              }
            }
          },
          "lagrangian": {
            "type": "object",
            "properties": {
              "simtime_start": {
                "type": "number"
              },
              "simtime_end": {
                "type": "number"
              },
              "ego_identifier": {
                "type": "string"
              }
            }
          },
          "cinematic": {
            "type": "object",
            "properties": {
              "simtime_start": {
                "type": "number"
              },
              "simtime_end": {
                "type": "number"
              },
              "ego_identifier": {
                "type": "string"
              },
              "camera_position_trajectory": {
                "type": "object",
                "patternProperties": {
                  "^[0-9]+(?:\\.[0-9]+)?$": {
                    "type": "object",
                    "properties": {
                      "pos_x": { "type": "number" },
                      "pos_y": { "type": "number" },
                      "pos_z": { "type": "number" },
                      "ori_h": { "type": "number" },
                      "ori_p": { "type": "number" },
                      "ori_r": { "type": "number" }
                    },
                    "required": ["pos_x", "pos_y", "pos_z", "ori_h", "ori_p", "ori_r"],
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "interactive": {
            "type": "object",
            "properties": {
              "initial_camera_position": {
                "type": "object",
                "properties": {
                  "position": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "Camera position as [x, y, z]",
                    "default": [120, -20, 0]
                  },
                  "orientation": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "Camera orientation as [heading, pitch, roll]",
                    "default": [180, 0, 0]
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}