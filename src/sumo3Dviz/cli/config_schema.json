{
  "type": "object",
  "properties": {
    "_validation_mode": {
      "type": "string",
      "enum": ["interactive", "eulerian", "lagrangian", "cinematic"],
      "description": "Internal field used for mode-specific validation"
    },
    "rendering": {
      "type": "object",
      "properties": {
        "record_video": {
          "type": "boolean",
          "default": true
        },
        "headless": {
          "type": "boolean",
          "default": false
        },
        "video_width_px": {
          "type": "integer",
          "default": 1140
        },
        "video_height_px": {
          "type": "integer",
          "default": 900
        },
        "video_fps": {
          "type": "number",
          "default": 25.0,
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        }
      },
      "additionalProperties": false
    },
    "visualization": {
      "type": "object",
      "properties": {
        "show_other_vehicles": {
          "type": "boolean",
          "default": true,
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        },
        "show_signals": {
          "type": "boolean",
          "default": true,
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        },
        "lane_width": {
          "type": "number",
          "default": 3.2
        },
        "sep_line_width": {
          "type": "number",
          "default": 0.2
        },
        "tree_scale_1": {
          "type": "number",
          "default": 0.2
        },
        "tree_scale_2": {
          "type": "number",
          "default": 0.5
        },
        "tree_size_variability": {
          "type": "number",
          "default": 1.0
        },
        "tree_color_variability": {
          "type": "number",
          "default": 0.1
        },
        "sky_texture": {
          "type": "string",
          "enum": [
            "sky_blue",
            "sky_cloudy",
            "sky_overcast",
            "sky_dawn",
            "sky_night_stars",
            "sky_night_clear",
            "sky_night_forest",
            "sky_night_desert",
            "sky_halloween"
          ],
          "default": "sky_cloudy"
        },
        "ground_texture": {
          "type": "string",
          "enum": [
            "ground_grass",
            "ground_stone",
            "ground_sand",
            "ground_chess",
            "ground_chesslarge",
            "ground_halloween"
          ],
          "default": "ground_grass"
        },
        "viewer_height": {
          "type": "number",
          "default": 1.5,
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "properties": {
        "trajectory_file": {
          "type": "string",
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        },
        "sumo_network_file": {
          "type": "string"
        },
        "traffic_signal_states_file": {
          "type": "string",
          "description": "Required for non-interactive modes (eulerian, lagrangian, cinematic)"
        },
        "fence_lines_file": {
          "type": "string"
        },
        "shops_positions_file": {
          "type": "string"
        },
        "homes_positions_file": {
          "type": "string"
        },
        "blocks_positions_file": {
          "type": "string"
        },
        "tree_positions_file": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "signals": {
      "type": "object",
      "description": "Required for non-interactive modes when 'show_signals' is enabled",
      "properties": {
        "signal_design": {
          "type": "string",
          "enum": ["simple", "three_headed", "countdown_timer"],
          "default": "three_headed"
        },
        "traffic_light_id": {
          "type": "string"
        },
        "traffic_light_positions": {
          "type": "object",
          "properties": {
            "ramps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "pos_x": { "type": "number" },
                  "pos_y": { "type": "number" },
                  "stop_line_a": { "type": "number" },
                  "stop_line_b": { "type": "number" },
                  "stop_line_c": { "type": "number" },
                  "stop_line_d": { "type": "number" }
                },
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "modes": {
      "type": "object",
      "description": "At least one mode must be defined (eulerian, lagrangian, cinematic, or interactive). Non-interactive modes require additional fields in paths, rendering, visualization, and signals sections.",
      "minProperties": 1,
      "properties": {
        "eulerian": {
          "type": "object",
          "properties": {
            "simtime_start": {
              "type": "number"
            },
            "simtime_end": {
              "type": "number"
            },
            "ego_identifier": {
              "type": "string"
            },
            "camera_position": {
              "type": "object",
              "properties": {
                "pos_x": { "type": "number" },
                "pos_y": { "type": "number" },
                "pos_z": { "type": "number" },
                "ori_h": { "type": "number" },
                "ori_p": { "type": "number" },
                "ori_r": { "type": "number" }
              }
            }
          }
        },
        "lagrangian": {
          "type": "object",
          "properties": {
            "simtime_start": {
              "type": "number"
            },
            "simtime_end": {
              "type": "number"
            },
            "ego_identifier": {
              "type": "string"
            }
          }
        },
        "cinematic": {
          "type": "object",
          "properties": {
            "simtime_start": {
              "type": "number"
            },
            "simtime_end": {
              "type": "number"
            },
            "ego_identifier": {
              "type": "string"
            },
            "camera_position_trajectory": {
              "type": "object",
              "patternProperties": {
                "^[0-9]+(?:\\.[0-9]+)?$": {
                  "type": "object",
                  "properties": {
                    "pos_x": { "type": "number" },
                    "pos_y": { "type": "number" },
                    "pos_z": { "type": "number" },
                    "ori_h": { "type": "number" },
                    "ori_p": { "type": "number" },
                    "ori_r": { "type": "number" }
                  },
                  "required": [
                    "pos_x",
                    "pos_y",
                    "pos_z",
                    "ori_h",
                    "ori_p",
                    "ori_r"
                  ],
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "interactive": {
          "type": "object",
          "properties": {
            "initial_camera_position": {
              "type": "object",
              "properties": {
                "position": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "description": "Camera position as [x, y, z]",
                  "default": [120, -20, 0]
                },
                "orientation": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "description": "Camera orientation as [heading, pitch, roll]",
                  "default": [180, 0, 0]
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["modes", "paths", "rendering", "visualization"],
  "if": {
    "properties": {
      "_validation_mode": {
        "const": "interactive"
      }
    }
  },
  "then": {
    "properties": {
      "paths": {
        "required": ["sumo_network_file"]
      },
      "rendering": {
        "required": ["video_width_px", "video_height_px"]
      },
      "visualization": {
        "required": ["lane_width", "sky_texture", "ground_texture"]
      }
    }
  },
  "else": {
    "properties": {
      "paths": {
        "required": [
          "trajectory_file",
          "traffic_signal_states_file",
          "sumo_network_file"
        ]
      },
      "rendering": {
        "required": ["video_fps", "video_width_px", "video_height_px"]
      },
      "visualization": {
        "required": [
          "show_other_vehicles",
          "show_signals",
          "viewer_height",
          "lane_width",
          "sky_texture",
          "ground_texture"
        ]
      }
    }
  }
}
